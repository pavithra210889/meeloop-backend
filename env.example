# ============================================
# Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ============================================
# Database Configuration
# ============================================
DATABASE_URL=sqlite:///./database.sqlite
DATABASE_ECHO=false

# ============================================
# Security Configuration
# ============================================
# Generate a secure random key for production
# You can use: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# Firebase Configuration
# ============================================
# Firebase credentials for push notifications
# Get from Firebase Console -> Project Settings -> Service Accounts
FIREBASE_CREDENTIALS=
FIREBASE_PROJECT_ID=

# ============================================
# Media Configuration
# ============================================
MEDIA_ROOT=media
MAX_FILE_SIZE=10485760

# ============================================
# Cloudflare R2 Storage Configuration
# ============================================
# For storing media files in Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
R2_REGION=auto

# ============================================
# Notifications
# ============================================
ENABLE_PUSH_NOTIFICATIONS=true

# ============================================
# CORS Configuration
# ============================================
# Comma-separated list of allowed origins
# Use "*" for development, specific domains for production
CORS_ORIGINS=*

# ============================================
# Socket.IO Configuration
# ============================================
SOCKETIO_CORS_ORIGINS=*

# Redis URL for Socket.IO multi-worker support (required in production with multiple workers)
# Format: redis://[password@]host:port/db
REDIS_URL=redis://localhost:6379/0

# ============================================
# Admin Configuration
# ============================================
# Comma-separated list of admin usernames
ADMIN_USERNAMES=

# ============================================
# IP Geolocation (ipinfo.io)
# ============================================
# Optional: Get token from https://ipinfo.io/
IPINFO_TOKEN=

# ============================================
# Frontend URL
# ============================================
# Used for OAuth redirects after authentication
FRONTEND_URL=http://localhost:3000

# ============================================
# Google OAuth Configuration
# ============================================
# Get from Google Cloud Console: https://console.cloud.google.com/
# 1. Create OAuth 2.0 Client ID
# 2. Add authorized redirect URI: http://your-backend-url/auth/google/callback/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback/

# ============================================
# Truecaller SDK Configuration
# ============================================
# Get from Truecaller Developer Portal: https://developer.truecaller.com/
TRUECALLER_APP_KEY=

# ============================================
# Facebook OAuth Configuration
# ============================================
# Get from Facebook Developers: https://developers.facebook.com/
# 1. Create a new app
# 2. Add Facebook Login product
# 3. Add OAuth redirect URI: http://your-backend-url/auth/facebook/callback/
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:8000/auth/facebook/callback/

# ============================================
# GIPHY (GIF search in chat)
# ============================================
# Get a free API key at https://developers.giphy.com/
# Create an app -> copy the API key
GIPHY_API_KEY=

# ============================================
# Google Maps (static map proxy for location messages)
# ============================================
# 1. Go to console.cloud.google.com -> APIs & Services -> Enable "Maps Static API"
# 2. Create an API key and restrict it to this server's IP address
# 3. Free tier: $200/month credit = ~100k map requests free
GOOGLE_MAPS_API_KEY=

# ============================================
# SMS Service Configuration (MSG91)
# ============================================
# For OTP-based phone authentication
# Options: "msg91" (production) or "mock" (development - logs OTP instead of sending)
SMS_PROVIDER=mock
# Set to false to prevent real SMS sending even if SMS_PROVIDER is set to msg91
ENABLE_OTP=true

# MSG91 Configuration
# Get from MSG91 Dashboard: https://control.msg91.com/
# 1. Sign up at https://msg91.com/
# 2. Get Auth Key from Dashboard -> Developer Platform
# 3. Create SMS template (optional but recommended)
# 4. Get Template ID from Templates section
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=MSG91

# ============================================
# TURN Server (coturn with use-auth-secret)
# ============================================
# The shared secret configured in coturn's static-auth-secret
TURN_SECRET=
# TURN server address (host:port)
TURN_SERVER=80.225.224.38:3478
# Credential TTL in seconds (default: 3600 = 1 hour)
TURN_TTL=3600

# ============================================
# Passkeys (WebAuthn)
# ============================================
# RP_ID must be your deployed web domain (where /.well-known/assetlinks.json is hosted)
RP_ID=meeloop.com
RP_NAME=Meeloop
# RP_ORIGIN accepted for browser registrations
RP_ORIGIN=https://meeloop.com
# base64url of SHA-256 cert fingerprint bytes from assetlinks.json (enables Android passkeys)
# Compute: python3 -c "import base64,binascii; print(base64.urlsafe_b64encode(binascii.unhexlify('<fingerprint_no_colons>')).decode().rstrip('='))"
ANDROID_APK_KEY_HASH=

